import SwiftUI

// MARK: - Duolingo-Style Winding Progress Path
struct WindingProgressPath: View {
    @EnvironmentObject var appState: AppState
    @Environment(\.dismiss) var dismiss
    
    @State private var selectedLevel: Int?
    @State private var showChallenge: Bool = false
    
    let totalLevels = 250
    let nodeSize: CGFloat = 60
    
    var body: some View {
        ZStack {
            // Background
            LinearGradient(colors: [Color(hex: "0A0F1C"), Color(hex: "1E293B")], startPoint: .top, endPoint: .bottom)
                .ignoresSafeArea()
            
            ScrollView {
                ZStack {
                    // Draw path using simple shapes
                    pathVisualization
                    
                    // Level nodes
                    ForEach(0..<50, id: \.self) { index in
                        let pos = getPosition(for: index)
                        let level = index + 1
                        let isLocked = level > (appState.progress?.level ?? 1)
                        let isCompleted = level < (appState.progress?.level ?? 1)
                        let isCurrent = level == (appState.progress?.level ?? 1)
                        
                        LevelNodeWithLabel(
                            level: level,
                            isLocked: isLocked,
                            isCompleted: isCompleted,
                            isCurrent: isCurrent
                        ) {
                            selectedLevel = level
                            let challenges = AllChallengeType.allCases
                            appState.selectedChallenge = challenges[level % challenges.count]
                            showChallenge = true
                        }
                        .position(x: pos.x, y: pos.y)
                            
                            // Milestone markers every 10 levels
                            if level % 10 == 0 && level > 0 {
                                MilestoneMarker(level: level)
                                    .position(x: pos.x, y: pos.y - 60)
                            }
                        }
                    }
                }
                .frame(height: 5800)
            }
            
            // Floating header
            VStack {
                floatingHeader
                Spacer()
            }
        }
        .navigationBarBackButtonHidden(true)
        .sheet(isPresented: $showChallenge) {
            if let level = selectedLevel {
                ChallengePreviewSheet(level: level, isPresented: $showChallenge) {
                    // Start the challenge
                    appState.startChallengeFromPath = true
                    appState.selectedTab = .practice
                    dismiss()
                }
            }
        }
    }
    
    func getPosition(for index: Int) -> CGPoint {
        let screenWidth = UIScreen.main.bounds.width
        let centerX = screenWidth / 2
        let amplitude: CGFloat = 80
        let y = CGFloat(index) * 110 + 240  // More space for labels
        let phase = Double(index) * 0.4
        let x = centerX + CGFloat(sin(phase)) * amplitude
        return CGPoint(x: x, y: y)
    }
    
    var pathVisualization: some View {
        Canvas { context, size in
            let screenWidth = UIScreen.main.bounds.width
            let centerX = screenWidth / 2
            
            var path = Path()
            path.move(to: CGPoint(x: centerX, y: 80))
            
            for i in 0..<50 {
                let pos = getPosition(for: i)
                path.addLine(to: pos)
            }
            
            context.stroke(path, with: .color(.purple.opacity(0.3)), lineWidth: 4)
        }
    }
    
    var floatingHeader: some View {
        VStack(spacing: 0) {
            HStack {
                Button { dismiss() } label: {
                    Image(systemName: "chevron.left").font(.system(size: 20, weight: .semibold)).foregroundColor(.white).frame(width: 44, height: 44)
                }
                
                Spacer()
                
                Text("Focus Journey")
                    .font(.system(size: 20, weight: .bold)).foregroundColor(.white)
                
                Spacer()
                
                // Stats
                HStack(spacing: 12) {
                    // Hearts
                    HStack(spacing: 4) {
                        Image(systemName: "heart.fill").font(.system(size: 12)).foregroundColor(.red)
                        Text("\(appState.progress?.hearts ?? 5)").font(.system(size: 14, weight: .bold)).foregroundColor(.white)
                    }
                    .padding(.horizontal, 10).padding(.vertical, 6).background(Capsule().fill(Color.red.opacity(0.2)))
                    
                    // Gems
                    HStack(spacing: 4) {
                        Image(systemName: "gem.fill").font(.system(size: 12)).foregroundColor(.cyan)
                        Text("\(appState.progress?.gems ?? 0)").font(.system(size: 14, weight: .bold)).foregroundColor(.white)
                    }
                    .padding(.horizontal, 10).padding(.vertical, 6).background(Capsule().fill(Color.cyan.opacity(0.2)))
                    
                    // Streak
                    HStack(spacing: 4) {
                        Image(systemName: "flame.fill").font(.system(size: 12)).foregroundColor(.orange)
                        Text("\(appState.progress?.streakDays ?? 0)").font(.system(size: 14, weight: .bold)).foregroundColor(.white)
                    }
                    .padding(.horizontal, 10).padding(.vertical, 6).background(Capsule().fill(Color.orange.opacity(0.2)))
                }
            }
            .padding(.horizontal, 16).padding(.top, 8)
            
            // Progress to next level
            VStack(spacing: 8) {
                HStack {
                    Text("Level \(appState.progress?.level ?? 1)")
                        .font(.system(size: 14, weight: .bold))
                        .foregroundColor(.white)
                    
                    Spacer()
                    
                    Text("\(appState.progress?.totalXP ?? 0) / \(appState.progress?.xpForNextLevel ?? 1000) XP")
                        .font(.system(size: 12, weight: .medium))
                        .foregroundColor(.gray)
                    
                    Text("Lv.\(min((appState.progress?.level ?? 1) + 1, totalLevels))")
                        .font(.system(size: 14, weight: .bold))
                        .foregroundColor(.purple)
                }
                
                GeometryReader { geo in
                    ZStack(alignment: .leading) {
                        RoundedRectangle(cornerRadius: 6).fill(Color.white.opacity(0.1))
                        RoundedRectangle(cornerRadius: 6)
                            .fill(
                                LinearGradient(
                                    colors: [.purple, .indigo],
                                    startPoint: .leading,
                                    endPoint: .trailing
                                )
                            )
                            .frame(width: geo.size.width * levelProgressPercent)
                    }
                }
                .frame(height: 12)
                
                // Journey progress
                HStack {
                    Text("Journey: \(Int(progressPercent * 100))% complete")
                        .font(.system(size: 11))
                        .foregroundColor(.gray)
                    Spacer()
                    Text("\(totalLevels - (appState.progress?.level ?? 1)) levels to go")
                        .font(.system(size: 11))
                        .foregroundColor(.gray)
                }
            }
            .padding(.horizontal, 16).padding(.bottom, 12)
        }
        .background(.ultraThinMaterial)
    }
    
    var progressPercent: CGFloat {
        CGFloat(appState.progress?.level ?? 1) / CGFloat(totalLevels)
    }
    
    var levelProgressPercent: CGFloat {
        guard let progress = appState.progress else { return 0 }
        return CGFloat(progress.currentLevelXP) / CGFloat(max(progress.xpForNextLevel, 1))
    }
}

// MARK: - Level Node with Label
struct LevelNodeWithLabel: View {
    let level: Int
    let isLocked: Bool
    let isCompleted: Bool
    let isCurrent: Bool
    let onTap: () -> Void
    
    @State private var isPulsing: Bool = false
    
    var body: some View {
        VStack(spacing: 8) {
            // The node circle
            ZStack {
                // Pulse effect for current
                if isCurrent {
                    Circle()
                        .fill(Color.purple.opacity(0.3))
                        .frame(width: isPulsing ? 75 : 65, height: isPulsing ? 75 : 65)
                        .animation(
                            .easeInOut(duration: 1.0).repeatForever(autoreverses: true),
                            value: isPulsing
                        )
                }
                
                // Main circle
                Circle()
                    .fill(circleColor)
                    .frame(width: 56, height: 56)
                    .shadow(color: isCurrent ? .purple.opacity(0.6) : .black.opacity(0.3), radius: isCurrent ? 12 : 6)
                
                // Border
                Circle()
                    .stroke(borderColor, lineWidth: isCurrent ? 3 : (isCompleted ? 2 : 1))
                    .frame(width: 56, height: 56)
                
                // Content
                if isLocked {
                    Image(systemName: "lock.fill")
                        .font(.system(size: 20))
                        .foregroundColor(.gray)
                } else {
                    VStack(spacing: 0) {
                        Text("\(level)")
                            .font(.system(size: 16, weight: .bold))
                            .foregroundColor(.white)
                    }
                }
            }
            .onTapGesture {
                if !isLocked {
                    onTap()
                }
            }
            
            // Challenge type label below node
            if !isLocked {
                Text(challengeName)
                    .font(.system(size: 11, weight: .semibold))
                    .foregroundColor(challengeColor)
                    .lineLimit(1)
                    .frame(width: 70)
            }
        }
    }
    
    var challengeName: String {
        let names = ["Focus", "Memory", "Reaction", "Breath", "Discipline"]
        return names[level % names.count]
    }
    
    var challengeColor: Color {
        let colors: [Color] = [.purple, .blue, .orange, .cyan, .green]
        return colors[level % colors.count]
    }
    
    var circleColor: Color {
        if isLocked {
            return Color.white.opacity(0.1)
        }
        if isCompleted {
            return Color.green.opacity(0.4)
        }
        if isCurrent {
            return Color.purple.opacity(0.7)
        }
        return Color.white.opacity(0.2)
    }
    
    var borderColor: Color {
        if isCurrent { return .purple }
        if isCompleted { return .green }
        if isLocked { return Color.white.opacity(0.2) }
        return Color.white.opacity(0.4)
    }
}

struct LevelNodeSimple: View {
    let level: Int
    let isLocked: Bool
    let isCompleted: Bool
    let isCurrent: Bool
    
    @State private var isPulsing: Bool = false
    
    var body: some View {
        Button { } label: {
            ZStack {
                // Pulse effect for current
                if isCurrent {
                    Circle()
                        .fill(Color.purple.opacity(0.2))
                        .frame(width: isPulsing ? 75 : 65, height: isPulsing ? 75 : 65)
                        .animation(
                            .easeInOut(duration: 1.0).repeatForever(autoreverses: true),
                            value: isPulsing
                        )
                }
                
                // Glow for completed
                if isCompleted {
                    Circle()
                        .fill(Color.green.opacity(0.15))
                        .frame(width: 65, height: 65)
                }
                
                // Main circle
                Circle()
                    .fill(circleColor)
                    .frame(width: 56, height: 56)
                    .shadow(color: isCurrent ? .purple.opacity(0.5) : .clear, radius: 8)
                
                // Border
                Circle()
                    .stroke(borderColor, lineWidth: isCurrent ? 3 : (isCompleted ? 2 : 1))
                    .frame(width: 56, height: 56)
                
                // Content
                if isLocked {
                    Image(systemName: "lock.fill")
                        .font(.system(size: 20))
                        .foregroundColor(.gray)
                } else {
                    VStack(spacing: 2) {
                        Text("\(level)")
                            .font(.system(size: 18, weight: .bold))
                            .foregroundColor(.white)
                        if isCompleted {
                            Image(systemName: "checkmark")
                                .font(.system(size: 10, weight: .bold))
                                .foregroundColor(.green)
                        }
                    }
                }
            }
        }
        .disabled(isLocked)
        .onAppear {
            if isCurrent {
                isPulsing = true
            }
        }
    }
    
    var circleColor: LinearGradient {
        if isLocked {
            return LinearGradient(
                colors: [Color.white.opacity(0.1), Color.white.opacity(0.05)],
                startPoint: .topLeading,
                endPoint: .bottomTrailing
            )
        }
        if isCompleted {
            return LinearGradient(
                colors: [Color.green.opacity(0.5), Color.green.opacity(0.3)],
                startPoint: .topLeading,
                endPoint: .bottomTrailing
            )
        }
        if isCurrent {
            return LinearGradient(
                colors: [Color.purple.opacity(0.7), Color.purple.opacity(0.5)],
                startPoint: .topLeading,
                endPoint: .bottomTrailing
            )
        }
        return LinearGradient(
            colors: [Color.white.opacity(0.25), Color.white.opacity(0.15)],
            startPoint: .topLeading,
            endPoint: .bottomTrailing
        )
    }
    
    var borderColor: Color {
        if isCurrent { return .purple }
        if isCompleted { return .green }
        if isLocked { return Color.white.opacity(0.2) }
        return Color.white.opacity(0.4)
    }
}

// MARK: - Milestone Marker
struct MilestoneMarker: View {
    let level: Int
    
    var body: some View {
        VStack(spacing: 4) {
            Image(systemName: milestoneIcon)
                .font(.system(size: 14, weight: .bold))
                .foregroundColor(milestoneColor)
            
            Text("Lv.\(level)")
                .font(.system(size: 9, weight: .bold))
                .foregroundColor(milestoneColor)
        }
        .padding(.horizontal, 8)
        .padding(.vertical, 4)
        .background(
            Capsule()
                .fill(milestoneColor.opacity(0.2))
        )
        .overlay(
            Capsule()
                .stroke(milestoneColor.opacity(0.5), lineWidth: 1)
        )
    }
    
    var milestoneIcon: String {
        switch level {
        case 10: return "star.fill"
        case 25: return "sparkles"
        case 50: return "crown.fill"
        case 75: return "trophy.fill"
        case 100: return "medal.fill"
        case 150: return "gem.fill"
        case 200: return "star.circle.fill"
        default: return "flag.fill"
        }
    }
    
    var milestoneColor: Color {
        switch level {
        case 10: return .yellow
        case 25: return .orange
        case 50: return .green
        case 75: return .blue
        case 100: return .purple
        case 150: return .pink
        case 200: return .red
        default: return .white
        }
    }
}

// MARK: - Challenge Preview Sheet
struct ChallengePreviewSheet: View {
    let level: Int
    @Binding var isPresented: Bool
    let onStart: () -> Void
    
    var body: some View {
        NavigationStack {
            ZStack {
                Color(hex: "0A0F1C").ignoresSafeArea()
                
                VStack(spacing: 24) {
                    Spacer()
                        .frame(height: 40)
                    
                    // Level badge
                    VStack(spacing: 12) {
                        Text("LEVEL \(level)")
                            .font(.system(size: 12, weight: .bold))
                            .foregroundColor(.purple)
                            .tracking(2)
                        
                        Text(challengeTitle)
                            .font(.system(size: 24, weight: .bold))
                            .foregroundColor(.white)
                            .multilineTextAlignment(.center)
                    }
                    
                    // Challenge type icon
                    Image(systemName: challengeIcon)
                        .font(.system(size: 70))
                        .foregroundColor(challengeColor)
                        .padding(.vertical, 20)
                    
                    // Description
                    Text(challengeDescription)
                        .font(.system(size: 15))
                        .foregroundColor(.gray)
                        .multilineTextAlignment(.center)
                        .padding(.horizontal, 32)
                    
                    // Rewards
                    HStack(spacing: 20) {
                        // XP reward
                        HStack(spacing: 6) {
                            Image(systemName: "star.fill")
                            Text("\(xpReward) XP")
                        }
                        .font(.system(size: 18, weight: .bold))
                        .foregroundColor(.yellow)
                        .padding(.horizontal, 16)
                        .padding(.vertical, 10)
                        .background(
                            Capsule()
                                .fill(Color.yellow.opacity(0.2))
                        )
                        
                        // Gem reward
                        if gemReward > 0 {
                            HStack(spacing: 6) {
                                Image(systemName: "gem.fill")
                                Text("\(gemReward)")
                            }
                            .font(.system(size: 18, weight: .bold))
                            .foregroundColor(.cyan)
                            .padding(.horizontal, 16)
                            .padding(.vertical, 10)
                            .background(
                                Capsule()
                                    .fill(Color.cyan.opacity(0.2))
                            )
                        }
                    }
                    
                    Spacer()
                    
                    // Start button
                    Button(action: onStart) {
                        HStack {
                            Image(systemName: "play.fill")
                            Text("Start Challenge")
                        }
                        .font(.system(size: 18, weight: .semibold))
                        .foregroundColor(.white)
                        .frame(maxWidth: .infinity)
                        .padding(.vertical, 18)
                        .background(
                            LinearGradient(colors: [.purple, .indigo], startPoint: .leading, endPoint: .trailing)
                        )
                        .cornerRadius(16)
                    }
                    .padding(.horizontal, 24)
                }
            }
        }
    }
    
    var challengeTitle: String {
        let types = ["Focus Master", "Memory Boost", "Reaction Time", "Breathing Calm", "Discipline Train"]
        return types[level % types.count]
    }
    
    var challengeIcon: String {
        let icons = ["target", "brain.head.profile", "bolt.fill", "wind", "hand.raised.fill"]
        return icons[level % icons.count]
    }
    
    var challengeColor: Color {
        let colors: [Color] = [.purple, .blue, .orange, .cyan, .green]
        return colors[level % colors.count]
    }
    
    var challengeDescription: String {
        let descriptions = [
            "Train your focus to stay on task",
            "Improve your memory recall",
            "Speed up your reaction time",
            "Calm your mind with breathing",
            "Build self-discipline"
        ]
        return descriptions[level % descriptions.count]
    }
    
    var xpReward: Int {
        50 + (level * 10)
    }
    
    var gemReward: Int {
        if level % 5 == 0 { return 3 }
        if level % 2 == 0 { return 1 }
        return 0
    }
}

#Preview {
    WindingProgressPath().environmentObject(AppState())
}
