                .frame(height: 12)
                
                Text(disciplineEncouragement)
                    .font(.system(size: 14))
                    .foregroundColor(.white.opacity(0.8))
            }
            .padding(.horizontal)
            
            Spacer()
            
            VStack(spacing: 16) {
                ZStack {
                    Circle().fill(temptationColor.opacity(0.2)).frame(width: 180, height: 180)
                    Circle().stroke(temptationColor, lineWidth: 3).frame(width: 160, height: 160)
                    VStack(spacing: 12) {
                        Image(systemName: disciplineIcon).font(.system(size: 50)).foregroundColor(temptationColor)
                        Text("Don't tap!").font(.system(size: 16, weight: .bold)).foregroundColor(.white)
                    }
                }
                Text("Let it pass...").font(.system(size: 14)).foregroundColor(.gray)
            }
            
            Spacer()
            
            HStack(spacing: 32) {
                VStack {
                    Text("\(combo)").font(.system(size: 20, weight: .bold)).foregroundColor(.green)
                    Text("Resisted").font(.system(size: 12)).foregroundColor(.gray)
                }
                VStack {
                    Text("\(score)").font(.system(size: 20, weight: .bold)).foregroundColor(.yellow)
                    Text("Score").font(.system(size: 12)).foregroundColor(.gray)
                }
            }
        }
        .padding()
    }
    
    var scrollResistanceView: some View {
        VStack(spacing: 30) {
            Text("Scroll Resistance")
                .font(.title2)
                .foregroundColor(.white)
            
            Text("Don't give in to the urge!")
                .font(.subheadline)
                .foregroundColor(.gray)
            
            // Fake scroll indicator
            VStack(spacing: 16) {
                Rectangle()
                    .fill(Color.white.opacity(0.1))
                    .frame(height: 200)
                    .overlay(
                        VStack {
                            Image(systemName: "arrow.down").font(.title)
                            Text("Content below").font(.caption)
                        }
                        .foregroundColor(.gray)
                    )
                
                // Temptation grows
                Text("You want to scroll...")
                    .foregroundColor(temptationColor)
                    .padding(.vertical, 8)
                
                // Resist button (wrong action)
                Button(action: {
                    temptationLevel = min(1.0, temptationLevel + 0.2)
                    score = max(0, score - 10)
                    combo = 0
                }) {
                    Text("SCROLL DOWN")
                        .font(.headline)
                        .foregroundColor(.white)
                        .padding()
                        .background(Color.red.opacity(0.5))
                        .cornerRadius(8)
                }
                
                // Correct action - look away
                Button(action: {
                    combo += 1
                    temptationLevel = max(0, temptationLevel - 0.1)
                    score += 20
                }) {
                    Text("LOOK AWAY ✓")
                        .font(.headline)
                        .foregroundColor(.green)
                        .padding()
                        .background(Color.green.opacity(0.2))
                        .cornerRadius(8)
                }
            }
            .padding()
            
            HStack {
                VStack {
                    Text("\(combo)").foregroundColor(.green)
                    Text("Resisted").font(.caption).foregroundColor(.gray)
                }
                Spacer()
                VStack {
                    Text("\(score)").foregroundColor(.yellow)
                    Text("Score").font(.caption).foregroundColor(.gray)
                }
            }
            .padding(.horizontal)
        }
    }
    
    var notificationResistanceView: some View {
        VStack(spacing: 30) {
            Text("Ignore the Notification")
                .font(.title2)
                .foregroundColor(.white)
            
            // Fake notification
            VStack(alignment: .leading, spacing: 12) {
                HStack {
                    Image(systemName: "bell.badge.fill")
                        .foregroundColor(.red)
                    Text("New Message")
                        .font(.headline)
                        .foregroundColor(.white)
                    Spacer()
                    Text("now")
                        .font(.caption)
                        .foregroundColor(.gray)
                }
                Text("Hey! Check this out...")
                    .font(.subheadline)
                    .foregroundColor(.gray)
                
                HStack {
                    Button(action: {
                        temptationLevel = min(1.0, temptationLevel + 0.3)
                        score = max(0, score - 20)
                        combo = 0
                    }) {
                        Text("View").foregroundColor(.white).padding(.horizontal, 20).padding(.vertical, 10).background(Color.blue).cornerRadius(8)
                    }
                    Button(action: {
                        combo += 1
                        score += 30
                        temptationLevel = max(0, temptationLevel - 0.2)
                    }) {
                        Text("Dismiss").foregroundColor(.white).padding(.horizontal, 20).padding(.vertical, 10).background(Color.gray).cornerRadius(8)
                    }
                }
            }
            .padding()
            .background(Color.white.opacity(0.1))
            .cornerRadius(16)
            .padding(.horizontal)
            
            HStack {
                Text("Temptation: \(Int(temptationLevel * 100))%").foregroundColor(temptationColor)
                Spacer()
                Text("Score: \(score)").foregroundColor(.yellow)
            }
            .padding(.horizontal)
            
            Text("Don't open notifications!")
                .font(.caption)
                .foregroundColor(.gray)
        }
    }
    
