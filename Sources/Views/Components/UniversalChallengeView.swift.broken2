            ZStack {
                Circle()
                    .stroke(Color.white.opacity(0.1), lineWidth: 8)
                    .frame(width: 200, height: 200)
                
                Circle()
                    .fill(combo > 20 ? Color.green.opacity(0.5) : (combo > 10 ? Color.yellow.opacity(0.5) : Color.red.opacity(0.5)))
                    .frame(width: 100, height: 100)
                
                VStack {
                    Text("\(combo)")
                        .font(.system(size: 48, weight: .bold))
                        .foregroundColor(.white)
                    Text("seconds")
                        .font(.caption)
                        .foregroundColor(.gray)
                }
            }
            
            Text(combo > 10 ? "Great hold!" : "Keep holding!")
                .foregroundColor(.white)
            
            Button(action: {
                temptationLevel = min(1.0, temptationLevel + 0.1)
            }) {
                Text("Release")
                    .foregroundColor(.white)
                    .padding()
                    .background(Color.red.opacity(0.5))
                    .cornerRadius(8)
            }
        }
    }
    
    var impulseDelayView: some View {
        VStack(spacing: 30) {
            Text("Impulse Delay")
                .font(.title2)
                .foregroundColor(.white)
            
            Text("Wait before acting...")
                .font(.subheadline)
                .foregroundColor(.gray)
            
            // Countdown
            ZStack {
                Circle()
                    .stroke(Color.white.opacity(0.1), lineWidth: 8)
                    .frame(width: 200, height: 200)
                
                Circle()
                    .trim(from: 0, to: CGFloat(challengeTime) / CGFloat(challenge.duration))
                    .stroke(challenge.color, style: StrokeStyle(lineWidth: 8, lineCap: .round))
                    .frame(width: 200, height: 200)
                    .rotationEffect(.degrees(-90))
                
                VStack {
                    Text("\(challenge.duration - challengeTime)")
                        .font(.system(size: 48, weight: .bold))
                        .foregroundColor(.white)
                }
            }
            
            Button(action: {
                score += 50
                combo += 1
            }) {
                Text("ACT NOW!")
                    .font(.headline)
                    .foregroundColor(.white)
                    .padding()
                    .background(challenge.color)
                    .cornerRadius(8)
            }
            
            Text("Wait longer for more points!")
                .font(.caption)
                .foregroundColor(.gray)
        }
    }
    
    var distractionLogView: some View {
        VStack(spacing: 20) {
            Text("Distraction Log")
                .font(.title2)
                .foregroundColor(.white)
            
            Text("Note what distracts you")
