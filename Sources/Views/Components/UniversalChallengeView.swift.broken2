                                .foregroundColor(.white)
                            Spacer()
                            Button(action: {
                                temptationLevel = min(1.0, temptationLevel + 0.1)
                                combo = 0
                            }) {
                                Image(systemName: "plus.circle.fill").foregroundColor(.red)
                            }
                        }
                        .padding()
                        .background(Color.white.opacity(0.05))
                        .cornerRadius(8)
                    }
                }
            }
            .frame(height: 200)
            
            HStack {
                Text("Distractions: \(Int(temptationLevel * 10))").foregroundColor(.gray)
                Spacer()
                Text("Score: \(score)").foregroundColor(.yellow)
            }
        }
    }
                        .foregroundColor(.white)
                    Text("\(combo) impulses resisted")
                        .font(.system(size: 14))
                        .foregroundColor(.gray)
                }
                Spacer()
                VStack(alignment: .trailing) {
                    Text("\(score)")
                        .font(.system(size: 24, weight: .bold))
                        .foregroundColor(.yellow)
                    Text("discipline")
                        .font(.system(size: 12))
                        .foregroundColor(.gray)
                }
            }
            
            // Temptation meter
            VStack(spacing: 8) {
                HStack {
                    Image(systemName: "brain.head.profile").foregroundColor(.purple)
                    Text("Temptation Level")
                        .font(.system(size: 14, weight: .medium))
                        .foregroundColor(.gray)
                    Spacer()
                    Text("\(Int(temptationLevel * 100))%")
                        .font(.system(size: 14, weight: .bold))
                        .foregroundColor(temptationColor)
                }
                
                // Progress bar
                GeometryReader { geo in
                    ZStack(alignment: .leading) {
                        RoundedRectangle(cornerRadius: 8).fill(Color.white.opacity(0.1)).frame(height: 12)
                        RoundedRectangle(cornerRadius: 8)
                            .fill(
                                LinearGradient(
                                    colors: [.green, .yellow, .orange, .red],
                                    startPoint: .leading,
                                    endPoint: .trailing
                                )
                            )
                            .frame(width: geo.size.width * temptationLevel, height: 12)
                    }
                }
                .frame(height: 12)
                
                Text(disciplineEncouragement)
                    .font(.system(size: 14))
                    .foregroundColor(.white.opacity(0.8))
            }
            .padding(.horizontal)
            
            Spacer()
            
            // Main temptation scenario
            VStack(spacing: 16) {
                ZStack {
                    Circle()
                        .fill(temptationColor.opacity(0.2))
                        .frame(width: 180, height: 180)
                    Circle()
                        .stroke(temptationColor, lineWidth: 3)
                        .frame(width: 160, height: 160)
                    VStack(spacing: 12) {
                        Image(systemName: disciplineIcon)
                            .font(.system(size: 50))
                            .foregroundColor(temptationColor)
                        Text("Don't tap!")
                            .font(.system(size: 16, weight: .bold))
                            .foregroundColor(.white)
                    }
                }
                
                Text("Let it pass...")
                    .font(.system(size: 14))
                    .foregroundColor(.gray)
            }
            
            Spacer()
            
            // Stats
            HStack(spacing: 32) {
                VStack {
                    Text("\(combo)")
                        .font(.system(size: 20, weight: .bold))
                        .foregroundColor(.green)
                    Text("Resisted")
                        .font(.system(size: 12))
                        .foregroundColor(.gray)
                }
                VStack {
                    Text("\(score)")
                        .font(.system(size: 20, weight: .bold))
                        .foregroundColor(.yellow)
                    Text("Score")
                        .font(.system(size: 12))
                        .foregroundColor(.gray)
                }
            }
        }
        .padding()
    }
    
    var temptationColor: Color {
        if temptationLevel < 0.3 { return .green }
        if temptationLevel < 0.6 { return .yellow }
        if temptationLevel < 0.8 { return .orange }
        return .red
    }
    
    var disciplineIcon: String {
        let icons = ["bell.badge.fill", "app.badge", "hand.tap.fill", "bubble.left.fill", "exclamationmark.triangle.fill"]
        return icons[Int(timeRemaining) % icons.count]
    }
    
    var disciplineEncouragement: String {
        if temptationLevel < 0.3 { return "You're doing great! Stay calm." }
        if temptationLevel < 0.6 { return "Keep resisting. You got this!" }
        if temptationLevel < 0.8 { return "Focus on your breath. Don't react." }
        return "Almost there! Ride the urge!"
    }
    
    var challengeResultsView: some View {
        VStack(spacing: 24) {
            Spacer()
            Image(systemName: score >= 50 ? "star.fill" : "arrow.clockwise").font(.system(size: 60)).foregroundColor(score >= 50 ? .yellow : .gray)
            Text("Challenge Complete!").font(.title).foregroundColor(.white)
            Text("Score: \(score)").font(.title2).foregroundColor(.yellow)
            Text("+\(challenge.xpReward) XP").font(.headline).foregroundColor(.green)
            Button(action: { dismiss() }) { Text("Continue").foregroundColor(.white).padding().background(Color.blue).cornerRadius(8) }
            Spacer()
        }
    }
    
    func startChallenge() {
        isActive = true
        timeRemaining = Double(challenge.duration)
        score = 0
        combo = 0
        level = 1
        cycleCount = 0
        Timer.scheduledTimer(withTimeInterval: 0.1, repeats: true) { timer in
            if timeRemaining > 0 {
                timeRemaining -= 0.1
                challengeTime = challenge.duration - Int(timeRemaining)
            } else {
                timer.invalidate()
                showResults = true
            }
        }
    }
    
    func endChallenge() { isActive = false; showResults = true }
    
    func handleMemoryTap(_ index: Int) {
        // Simple memory game - tap all lit tiles
        if index % 2 == 0 && index < level * 2 {
            combo += 1
            score += 10 * min(combo, 5)
        } else {
            combo = 0
            score = max(0, score - 5)
        }
        
        // Progress to next level every 3 correct taps
        if score > level * 30 {
            level += 1
            combo = 0
        }
    }
    
    func moveSlowTarget(in size: CGSize) {
        withAnimation(.easeInOut(duration: 2.0)) {
            targetPosition = CGPoint(
                x: CGFloat.random(in: 0.15...0.85) * size.width,
                y: CGFloat.random(in: 0.15...0.7) * size.height
            )
        }
    }
    
    func handleReactionTap() {
        if gameState == .waiting || gameState == .ready {
            gameState = .tooEarly
            return
        }
        if gameState == .go {
            reactionTime = Date().timeIntervalSince(startTimeReact)
            score = max(0, Int((0.3 - reactionTime) * 1000))
            gameState = .waiting
            DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 1...3)) { startReaction() }
        }
    }
    
    func startReaction() {
        guard isActive else { return }
        gameState = .ready
        DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 1...3)) {
            gameState = .go
            startTimeReact = Date()
        }
    }
}

#Preview { UniversalChallengeView(challenge: .movingTarget).environmentObject(AppState()) }
