    var temptationColor: Color {
        if temptationLevel < 0.3 { return .green }
        if temptationLevel < 0.6 { return .yellow }
        if temptationLevel < 0.8 { return .orange }
        return .red
    }
    
    var disciplineScenarioIcon: String {
        let scenarios = ["bell.badge.fill", "app.badge", "hand.tap.fill", "bubble.left.fill", "exclamationmark.triangle.fill"]
        return scenarios[Int(timeRemaining) % scenarios.count]
    }
    
    var disciplineScenarioText: String {
        let texts = [
            "Notification appeared",
            "App wants to open",
            "Want to check something",
            "Message notification",
            "Alert pop-up"
        ]
        return texts[Int(timeRemaining) % texts.count]
    }
    
    var disciplineEncouragement: String {
        if temptationLevel < 0.3 { return "You're doing great! Stay calm." }
        if temptationLevel < 0.6 { return "Keep resisting. You got this!" }
        if temptationLevel < 0.8 { return "Focus on your breath. Don't react." }
        return "Almost there! Ride the urge!"
    }
    
    var reactionCircleColor: Color {
        switch gameState {
        case .waiting, .ready: return .red
        case .go: return .green
        case .tooEarly: return .orange
        }
    }
    
    var reactionCircleText: String {
        switch gameState {
        case .waiting, .ready: return "Wait..."
        case .go: return "TAP!"
        case .tooEarly: return "Too Early!"
        }
    }
    
    var breathIcon: String {
        switch breathPhase {
        case .inhale: return "arrow.up"
        case .hold: return "pause.circle"
        case .exhale: return "arrow.down"
        }
    }
    
    var disciplineButtonColor: Color {
        if showTarget { return .green }
        return temptationLevel > 0.7 ? .red : .orange
    }
    
    // MARK: - Challenge Logic
    
    func startChallenge() {
        isActive = true
        timeRemaining = Double(challenge.duration)
        score = 0
        level = 1
        cycleCount = 0
        challengeTime = 0
        
        Timer.scheduledTimer(withTimeInterval: 0.1, repeats: true) { timer in
            if timeRemaining > 0 {
                timeRemaining -= 0.1
                challengeTime += 1
                updateChallengeProgress()
            } else {
                timer.invalidate()
                challengeTime = challenge.duration - Int(timeRemaining)
                showResults = true
            }
        }
    }
    
    func updateChallengeProgress() {
        switch challenge.category {
        case .breathing:
            updateBreathing()
        case .discipline:
            temptationLevel = min(1.0, temptationLevel + 0.01)
        default:
            break
        }
    }
    
    func endChallenge() {
        isActive = false
        showResults = true
    }
    
    // MARK: - Focus Challenges
    func setupFocusChallenge(in size: CGSize) {
        instruction = challenge.description
        moveTarget(in: size)
        
        if challenge == .multiObjectTracking {
            targets = (0..<3).map { _ in randomPosition(in: size) }
        }
    }
    
    func moveTarget(in size: CGSize) {
        // Difficulty increases over time
        let difficultyMultiplier = 1.0 + (Double(challenge.duration - Int(timeRemaining)) / Double(challenge.duration)) * 0.5
        
        withAnimation(.easeInOut(duration: max(0.3, 0.8 / difficultyMultiplier))) {
            targetPosition = CGPoint(
                x: CGFloat.random(in: 0.15...0.85) * size.width,
                y: CGFloat.random(in: 0.15...0.65) * size.height
            )
        }
    }
    
    func randomPosition(in size: CGSize) -> CGPoint {
        CGPoint(
            x: CGFloat.random(in: 0.1...0.9) * size.width,
            y: CGFloat.random(in: 0.1...0.65) * size.height
        )
    }
    
    // MARK: - Memory Challenges
    func startMemoryLevel() {
        instruction = "Remember the pattern"
        pattern = (0..<(2 + level)).map { _ in Int.random(in: 0...8) }
        playerIndex = 0
        showingPattern = true
        
        DispatchQueue.main.asyncAfter(deadline: .now() + Double(level)) {
            showMemoryPattern()
        }
    }
    
    func showMemoryPattern() {
        for (i, index) in pattern.enumerated() {
            DispatchQueue.main.asyncAfter(deadline: .now() + Double(i) * 0.5) {
                grid[index] = 1
                DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                    grid[index] = 0
                }
            }
        }
        
        DispatchQueue.main.asyncAfter(deadline: .now() + Double(pattern.count) * 0.5 + 0.5) {
            showingPattern = false
            instruction = "Recreate the pattern"
        }
    }
    
    func handleMemoryTap(_ index: Int) {
        guard !showingPattern else { return }
        
        grid[index] = 1
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.2) {
            grid[index] = 0
        }
        
        if index == pattern[playerIndex] {
            playerIndex += 1
            if playerIndex >= pattern.count {
                score += level * 10
                level += 1
                startMemoryLevel()
            }
        } else {
            showingPattern = true
            DispatchQueue.main.asyncAfter(deadline: .now() + 1) {
                startMemoryLevel()
            }
        }
    }
    
    // MARK: - Reaction Challenges
    func startReactionChallenge() {
        instruction = "Wait for green"
        gameState = .waiting
        
        DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 2...4)) {
            gameState = .ready
            startTime = Date()
            
            DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 0.5...1.5)) {
                gameState = .go
            }
        }
    }
    
    func handleReactionTap() {
        switch gameState {
        case .waiting, .ready:
            gameState = .tooEarly
            scheduleReactionReset()
        case .go:
            reactionTime = Date().timeIntervalSince(startTime!)
            score = max(0, Int((0.5 - reactionTime) * 200))
            scheduleReactionReset()
        case .tooEarly:
            break
        }
    }
    
    func scheduleReactionReset() {
        DispatchQueue.main.asyncAfter(deadline: .now() + 1.5) {
            if isActive {
                startReactionChallenge()
            }
        }
    }
    
    // MARK: - Breathing Challenges
    func startBreathingChallenge() {
        instruction = "Follow the breathing"
        startBreathingCycle()
    }
    
    func startBreathingCycle() {
        breathPhase = .inhale
        breathProgress = 0
        
        withAnimation(.linear(duration: 4)) {
            breathProgress = 1
        }
        
        DispatchQueue.main.asyncAfter(deadline: .now() + 4) {
            breathPhase = .hold
            score += 10
            
            DispatchQueue.main.asyncAfter(deadline: .now() + 4) {
                breathPhase = .exhale
                breathProgress = 0
                
                withAnimation(.linear(duration: 4)) {
                    breathProgress = 1
                }
                
                DispatchQueue.main.asyncAfter(deadline: .now() + 4) {
                    cycleCount += 1
                    score += 10
                    if isActive {
                        startBreathingCycle()
                    }
                }
            }
        }
    }
    
    func updateBreathing() {
        // Breathing is handled by animations
    }
    
    // MARK: - Discipline Challenges
    func startDisciplineChallenge() {
        instruction = "Don't tap until green!"
        temptationLevel = 0
        
        DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 2...4)) {
            showTarget = true
            temptationLevel = 0
        }
    }
    
    func handleDisciplineTap() {
        if showTarget {
            score += Int(50 * (1 - temptationLevel))
            showTarget = false
            temptationLevel = 0
            
            DispatchQueue.main.asyncAfter(deadline: .now() + Double.random(in: 2...4)) {
                showTarget = true
            }
        } else {
            score = max(0, score - 10)
            temptationLevel = min(1.0, temptationLevel + 0.2)
        }
    }
    
    // MARK: - Results
    var challengeResultsView: some View {
        ZStack {
            // Confetti overlay
            if showConfetti {
                ConfettiView()
                    .allowsHitTesting(false)
            }
            
            VStack(spacing: 24) {
                Spacer()
                
                // Celebration header
                VStack(spacing: 8) {
                    Image(systemName: score >= 80 ? "trophy.fill" : (score >= 50 ? "star.fill" : "arrow.clockwise"))
                        .font(.system(size: 60))
                        .foregroundColor(score >= 80 ? .yellow : (score >= 50 ? .orange : .gray))
                        .scaleEffect(showPulse ? 1.2 : 1.0)
                        .animation(.spring(response: 0.5, dampingFraction: 0.5).repeatForever(autoreverses: true), value: showPulse)
                    
                    Text("Challenge Complete!")
                        .font(.system(size: 28, weight: .bold))
                        .foregroundColor(.white)
                }
                .padding(.top, 20)
                
                // Animated score ring
                ZStack {
                    Circle()
                        .stroke(Color.white.opacity(0.1), lineWidth: 16)
                        .frame(width: 200, height: 200)
                    
                    Circle()
                        .trim(from: 0, to: CGFloat(animatedScore) / 100)
                        .stroke(
                            AngularGradient(
                                colors: score >= 80 ? [.green, .yellow, .green] : (score >= 50 ? [.yellow, .orange, .yellow] : [.orange, .red, .orange]),
                                center: .center,
                                startAngle: .degrees(0),
                                endAngle: .degrees(360)
                            ),
                            style: StrokeStyle(lineWidth: 16, lineCap: .round)
                        )
                        .frame(width: 200, height: 200)
                        .rotationEffect(.degrees(-90))
                    
                    VStack(spacing: 4) {
                        Text("\(animatedScore)%")
                            .font(.system(size: 48, weight: .bold))
                            .foregroundColor(score >= 80 ? .green : (score >= 50 ? .yellow : .orange))
                        Text("SCORE")
                            .font(.system(size: 12, weight: .medium))
                            .foregroundColor(.gray)
                    }
                }
                .padding(.vertical, 16)
                
                // Performance message
                Text(scoreMessage)
                    .font(.system(size: 16, weight: .medium))
                    .foregroundColor(.gray)
                    .multilineTextAlignment(.center)
                    .padding(.horizontal, 32)
                
                // XP earned
                HStack(spacing: 8) {
                    Image(systemName: "star.fill")
                    Text("+\(calculateXP()) XP")
                }
                .font(.system(size: 22, weight: .bold))
                .foregroundColor(.yellow)
                .padding(.vertical, 12)
                .padding(.horizontal, 24)
                .background(
                    Capsule()
                        .fill(Color.yellow.opacity(0.2))
                )
                
                // Gems earned
                if calculateGems() > 0 {
                    HStack(spacing: 8) {
                        Image(systemName: "gem.fill")
                        Text("+\(calculateGems()) Gems")
                    }
                    .font(.system(size: 18, weight: .bold))
                    .foregroundColor(.cyan)
                    .padding(.vertical, 10)
                    .padding(.horizontal, 20)
                    .background(
                        Capsule()
                            .fill(Color.cyan.opacity(0.2))
                    )
                }
                
                // Detailed stats based on challenge type
                HStack(spacing: 16) {
                    switch challenge.category {
                    case .focus:
                        StatBox(icon: "hand.tap.fill", value: "\(totalTaps)", label: "Taps", color: .purple)
                        StatBox(icon: "flame.fill", value: "\(maxCombo)", label: "Max Combo", color: .orange)
                        StatBox(icon: "bolt.fill", value: "\(perfectTaps)", label: "Perfect", color: .green)
                    case .memory:
                        StatBox(icon: "brain.head.profile", value: "\(level)", label: "Level", color: .blue)
                        StatBox(icon: "clock.fill", value: "\(challengeTime)s", label: "Time", color: .purple)
                        StatBox(icon: "star.fill", value: "\(score)", label: "Score", color: .yellow)
                    case .reaction:
                        StatBox(icon: "bolt.fill", value: "\(Int(reactionTime * 1000))ms", label: "Reaction", color: .orange)
                        StatBox(icon: "target", value: "\(Int(accuracy))%", label: "Accuracy", color: .green)
                        StatBox(icon: "arrow.clockwise", value: "\(totalTaps)", label: "Attempts", color: .blue)
                    case .breathing:
                        StatBox(icon: "wind", value: "\(cycleCount)", label: "Cycles", color: .green)
                        StatBox(icon: "clock.fill", value: "\(challengeTime)s", label: "Time", color: .blue)
                        StatBox(icon: "heart.fill", value: "\(score)", label: "Calm Score", color: .red)
                    case .discipline:
                        StatBox(icon: "hand.raised.fill", value: "\(impulseResistedCount)", label: "Resisted", color: .green)
                        StatBox(icon: "xmark.circle.fill", value: "\(distractionCount)", label: "Gave In", color: .red)
                        StatBox(icon: "flame.fill", value: "\(score)", label: "Discipline", color: .orange)
                    }
                }
                .padding(.horizontal, 8)
                
                // Performance breakdown
                GlassCard(tint: challenge.color, cornerRadius: 16) {
                    VStack(spacing: 12) {
                        Text("Performance Breakdown")
                            .font(.system(size: 14, weight: .semibold))
                            .foregroundColor(.white)
                        
                        HStack {
                            PerformanceBar(label: "Accuracy", value: Double(score), color: .green)
                        }
                        HStack {
                            PerformanceBar(label: "Speed", value: Double(max(0, 100 - challengeTime * 2)), color: .blue)
                        }
                        HStack {
                            PerformanceBar(label: "Consistency", value: Double(score > 50 ? 80 : 50), color: .purple)
                        }
                    }
                }
                
                // Action buttons
                VStack(spacing: 12) {
                    GlassButton(title: "Continue", icon: "arrow.right", tint: challenge.color) {
                        completeChallenge()
                    }
                    
                    HStack(spacing: 16) {
                        Button {
                            // Share functionality
                        } label: {
                            HStack {
                                Image(systemName: "square.and.arrow.up")
                                Text("Share")
                            }
                            .font(.system(size: 14, weight: .medium))
                            .foregroundColor(.gray)
                            .frame(maxWidth: .infinity)
                            .padding(.vertical, 12)
                            .background(
                                RoundedRectangle(cornerRadius: 12)
                                    .stroke(Color.white.opacity(0.2), lineWidth: 1)
                            )
                        }
                        
                        Button {
                            resetChallenge()
                        } label: {
                            HStack {
                                Image(systemName: "arrow.counterclockwise")
                                Text("Retry")
                            }
                            .font(.system(size: 14, weight: .medium))
                            .foregroundColor(.gray)
                            .frame(maxWidth: .infinity)
                            .padding(.vertical, 12)
                            .background(
                                RoundedRectangle(cornerRadius: 12)
                                    .stroke(Color.white.opacity(0.2), lineWidth: 1)
                            )
                        }
                    }
                }
                .padding(.horizontal, 24)
                .padding(.bottom, 40)
            }
        }
        .onAppear {
            animateResults()
        }
    }
    
    // MARK: - Animation
    func animateResults() {
        // Pulse celebration
        showPulse = true
        
        // Show confetti for good scores
        if score >= 80 {
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                showConfetti = true
            }
        }
        
        // Animate score counter
        withAnimation(.easeOut(duration: 1.0)) {
            animatedScore = score
        }
    }
    
        let label: String
        let value: Double
        let color: Color
        
        var body: some View {
            HStack {
                Text(label)
                    .font(.system(size: 12))
                    .foregroundColor(.gray)
                    .frame(width: 80, alignment: .leading)
                
                GeometryReader { geo in
                    ZStack(alignment: .leading) {
                        RoundedRectangle(cornerRadius: 4)
                            .fill(Color.white.opacity(0.1))
                        
                        RoundedRectangle(cornerRadius: 4)
                            .fill(color)
                            .frame(width: geo.size.width * min(max(value / 100, 0), 1))
                    }
                }
                .frame(height: 8)
                
                Text("\(Int(value))%")
                    .font(.system(size: 12, weight: .medium))
                    .foregroundColor(.white)
                    .frame(width: 40, alignment: .trailing)
            }
        }
    }
    
    var scoreMessage: String {
        if score >= 90 { return "Outstanding! You're a focus master!" }
        if score >= 80 { return "Excellent work! Keep it up!" }
        if score >= 60 { return "Good job! Practice makes perfect." }
        if score >= 40 { return "Nice try! Give it another shot." }
        return "Keep practicing! You'll get better."
    }
    
    func calculateXP() -> Int {
        Int(Double(challenge.xpReward) * Double(score) / 100)
    }
    
    func calculateGems() -> Int {
        // Earn gems based on performance
        if score >= 100 {
            return 5  // Perfect score = 5 gems
        } else if score >= 90 {
            return 3  // Great score = 3 gems
        } else if score >= 70 {
            return 2  // Good score = 2 gems
        } else if score >= 50 {
            return 1  // Okay score = 1 gem
        }
        return 0  // Below 50% = no gems
    }
    
    func completeChallenge() {
        let xp = calculateXP()
        let gems = calculateGems()
        
        if var prog = appState.progress {
            prog.totalXP += xp
            prog.gems += gems  // Add gems
            prog.completedChallenges.append(ChallengeAttempt(
                id: UUID().uuidString,
                challengeTypeRaw: challenge.rawValue,
                level: level,
                score: score,
                duration: TimeInterval(challenge.duration),
                isPerfect: score >= 100,
                xpEarned: xp,
                attemptedAt: Date()
            ))
            appState.progress = prog
            appState.updateStreak()
            appState.saveData()
        }
        
        dismiss()
    }
    
